# docker-compose.yml reads this file for the broker container.
BIND_HOST=0.0.0.0
PORT=8788
RUST_LOG=relay_broker=info,tower_http=info
RELAY_BROKER_AUTH_MODE=self_hosted
RELAY_BROKER_TICKET_SECRET=change-me
# Optional: set a finite lifetime for saved device broker join credentials.
# RELAY_BROKER_DEVICE_JOIN_TTL_SECS=2592000
# Public broker mode instead uses broker-issued short-lived ws tokens plus
# refresh credentials. Example broker env:
# RELAY_BROKER_AUTH_MODE=public
# RELAY_BROKER_PUBLIC_ISSUER_SECRET=change-me
# Required when BIND_HOST is non-loopback in public mode. Use EITHER the JSON
# state path OR a Postgres URL (mutually exclusive). Postgres is recommended for
# durability and is required before multi-broker/HA.
# RELAY_BROKER_PUBLIC_STATE_PATH=/var/lib/agent-relay/public-control.json
# RELAY_BROKER_PUBLIC_POSTGRES_URL=postgres://user:pass@host/db
# Optional: usage event stream (connect/disconnect/publish analytics). Postgres
# takes precedence over the file path when both are set; point it at the same DB
# as RELAY_BROKER_PUBLIC_POSTGRES_URL to keep analytics in one place.
# RELAY_BROKER_USAGE_EVENTS_POSTGRES_URL=postgres://user:pass@host/db
# RELAY_BROKER_USAGE_EVENTS_PATH=/var/lib/agent-relay/usage-events.ndjson
# Optional: IP blocklist. Point at the same DB; reject banned IPs/CIDRs with 403.
# Ban via: INSERT INTO banned_ips (ip_or_cidr, reason) VALUES ('1.2.3.4','abuse');
# RELAY_BROKER_BANNED_IPS_POSTGRES_URL=postgres://user:pass@host/db
# Behind a reverse proxy the socket IP is the proxy's, so IP bans (and per-IP
# rate limits) would target the proxy. Set this to the header the proxy adds with
# the real client IP so bans apply to the actual client. Leave unset for direct
# connections / local dev (uses the socket IP; forwarded headers are NOT trusted).
# SECURITY: only set this if the broker is reachable ONLY through the trusted
# proxy (bind private / not publicly routable). If clients can reach the broker
# directly, they can forge this header to spoof or evade bans and rate limits.
# RELAY_BROKER_TRUSTED_CLIENT_IP_HEADER=cf-connecting-ip
# Optional public broker hardening:
# RELAY_BROKER_PUBLIC_API_RATE_LIMIT_PER_MINUTE=120
# RELAY_BROKER_JOIN_RATE_LIMIT_PER_MINUTE=40
# RELAY_BROKER_PUBLISH_RATE_LIMIT_PER_MINUTE=240
# RELAY_BROKER_MAX_CONNECTIONS_PER_IP=24
# RELAY_BROKER_MAX_TEXT_FRAME_BYTES=65536
# RELAY_BROKER_IDLE_TIMEOUT_SECS=120
# Optional: tighten production broker page CSP connect-src. Leave unset for
# dev/LAN-friendly defaults.
# RELAY_BROKER_CSP_CONNECT_SRC='self' https://broker.example.com wss://broker.example.com
# Enable only behind HTTPS with X-Forwarded-Proto: https
# RELAY_BROKER_ENABLE_HSTS=1
# Optional: override the default HSTS policy.
# RELAY_BROKER_HSTS_VALUE=max-age=86400

# relay-server should usually run outside this compose stack, close to the repo
# and Codex CLI session. Example:
#
# BIND_HOST=127.0.0.1 \
# PORT=8787 \
# RELAY_API_TOKEN=change-me \
# RELAY_SECURITY_MODE=private \
# RELAY_BROKER_URL=ws://127.0.0.1:8788 \
# RELAY_BROKER_PUBLIC_URL=ws://192.168.1.105:8788 \
# RELAY_BROKER_AUTH_MODE=self_hosted \
# RELAY_BROKER_CHANNEL_ID=dev-room \
# RELAY_BROKER_PEER_ID=local-relay \
# RELAY_BROKER_TICKET_SECRET=change-me \
# RELAY_BROKER_DEVICE_JOIN_TTL_SECS=2592000 \
# cargo run -p relay-server
#
# When BIND_HOST is non-loopback, RELAY_API_TOKEN is required by default.
# RELAY_ALLOW_INSECURE_NO_AUTH=1 only exists as an explicit insecure
# development override.
# Optional: tighten production relay page CSP connect-src. Leave unset for
# dev/LAN-friendly defaults.
# RELAY_CSP_CONNECT_SRC='self' https://relay.example.com wss://broker.example.com
# Enable only behind HTTPS with X-Forwarded-Proto: https
# RELAY_ENABLE_HSTS=1
# Optional: override the default HSTS policy.
# RELAY_HSTS_VALUE=max-age=86400
#
# Public mode relay example:
#
# RELAY_BROKER_URL=wss://broker.example.com \
# RELAY_BROKER_PUBLIC_URL=wss://broker.example.com \
# RELAY_BROKER_CONTROL_URL=https://broker.example.com \
# RELAY_BROKER_AUTH_MODE=public \
# RELAY_BROKER_PEER_ID=local-relay \
# RELAY_BROKER_REGISTRATION_PATH=.agent-relay/public-broker-registration.json \
# RELAY_BROKER_IDENTITY_PATH=.agent-relay/public-broker-identity.json \
# cargo run -p relay-server
#
# On first startup without a cached registration, the relay automatically
# creates a local signing key, completes the broker enrollment challenge, and
# caches relay_id + broker_room_id + relay_refresh_token locally.
