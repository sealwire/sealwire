{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sealwire",
  "version": "0.1.0",
  "identifier": "dev.sealwire.desktop",
  "build": {
    "beforeDevCommand": "node scripts/tauri-dev.mjs",
    "beforeBuildCommand": "node scripts/tauri-before-build.mjs --release",
    "devUrl": "http://127.0.0.1:5173/static/desktop.html",
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sealwire",
        "url": "desktop.html",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/relay-server", "binaries/node"],
    "resources": {
      "resources/claude-worker/": "claude-worker/"
    }
  }
}
