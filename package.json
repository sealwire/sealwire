{
  "name": "sealwire",
  "version": "0.1.0",
  "description": "Local-first, privacy-first control plane for coding agents (Codex & Claude Code) with optional public broker pairing.",
  "license": "Elastic-2.0",
  "author": "Yikai Lan <sealwire.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sealwire/sealwire.git"
  },
  "homepage": "https://github.com/sealwire/sealwire#readme",
  "bugs": "https://github.com/sealwire/sealwire/issues",
  "type": "module",
  "bin": {
    "sealwire": "./scripts/sealwire.mjs"
  },
  "files": [
    "bin/**",
    "Cargo.lock",
    "Cargo.toml",
    "LICENSE",
    "README.md",
    "crates/**",
    "scripts/sealwire.mjs",
    "web/**"
  ],
  "engines": {
    "node": ">=18"
  },
  "config": {
    "public_broker_origin": ""
  },
  "scripts": {
    "start": "node scripts/sealwire.mjs",
    "dev": "vite --host",
    "dev:full": "node scripts/dev-full.mjs",
    "dev:full:local": "RELAY_DEV_LOCALHOST_ONLY=1 node scripts/dev-full.mjs",
    "dev:restart": "sh scripts/restart-dev.sh",
    "dev:restart:local": "sh scripts/restart-dev.sh --local",
    "dev:restart:public": "sh scripts/restart-dev-public.sh",
    "test": "node --test claude-worker/*.test.mjs frontend/*.test.mjs frontend/local/*.test.mjs frontend/remote/*.test.mjs scripts/e2e/harness/*.test.mjs && vite build",
    "test:harness": "node --test scripts/e2e/harness/*.test.mjs",
    "test:message-drop-harness": "cargo test -p relay-server replay_harness -- --nocapture && cargo test -p relay-server compact_for_broker_trims_many_file_changes_without_clearing_transcript -- --nocapture",
    "build": "vite build",
    "prepack": "npm run build",
    "preview": "vite preview --host",
    "smoke:pairing": "node scripts/pairing-smoke.mjs",
    "test:claude:provider": "node scripts/claude-provider-e2e.mjs",
    "test:claude:browser": "node scripts/e2e/run-browser-suite.mjs --suite real-provider",
    "test:claude": "npm run test:claude:provider && npm run test:claude:browser",
    "test:browser:install": "playwright install chromium",
    "test:browser:install:ci": "playwright install --with-deps chromium",
    "test:browser:pairing": "node scripts/e2e/run-browser-suite.mjs --suite self-hosted",
    "test:browser:pairing:fake": "node scripts/e2e/run-browser-suite.mjs --suite self-hosted --fake",
    "test:browser:local-delete": "npm run build && node scripts/browser-local-delete-e2e.mjs",
    "test:browser:local-session": "npm run build && node scripts/browser-local-session-e2e.mjs",
    "test:browser:local-thread-settings": "npm run build && AGENT_PROVIDERS=fake node scripts/browser-local-thread-settings-e2e.mjs",
    "test:browser:local-thread-groups": "npm run build && node scripts/browser-local-thread-groups-e2e.mjs",
    "test:browser:local-history-scroll": "npm run build && node scripts/browser-local-history-scroll-e2e.mjs",
    "test:browser:local-drawer-scroll": "npm run build && AGENT_PROVIDERS=fake node scripts/browser-local-drawer-scroll-e2e.mjs",
    "test:browser:local-transcript-load": "npm run build && AGENT_PROVIDERS=fake node scripts/browser-local-transcript-load-e2e.mjs",
    "test:browser:local-allowed-roots": "npm run build && node scripts/browser-local-allowed-roots-e2e.mjs",
    "test:browser:local-file-diff": "npm run build && node scripts/browser-local-file-diff-e2e.mjs",
    "test:browser:local-auth": "npm run build && node scripts/browser-local-auth-e2e.mjs",
    "test:browser:local-core:fake": "node scripts/e2e/run-browser-suite.mjs --suite local-core --fake",
    "test:browser:local-full:fake": "node scripts/e2e/run-browser-suite.mjs --suite local-full --fake",
    "test:browser:public-enrollment": "npm run build && node scripts/browser-public-enrollment-e2e.mjs",
    "test:browser:public-broker": "npm run build && node scripts/browser-public-broker-e2e.mjs",
    "test:browser:public-reclaim": "npm run build && node scripts/browser-public-reclaim-e2e.mjs",
    "test:browser:public-refresh": "npm run build && node scripts/browser-public-refresh-e2e.mjs",
    "test:browser:public-persistence": "npm run build && node scripts/browser-public-persistence-e2e.mjs",
    "test:browser:public-revoke": "npm run build && node scripts/browser-public-revoke-e2e.mjs",
    "test:browser:public-long-transcript": "npm run build && node scripts/browser-public-long-transcript-e2e.mjs",
    "test:browser:public-transcript-delta": "npm run build && node scripts/browser-public-transcript-delta-e2e.mjs",
    "test:browser:public-thread-settings": "npm run build && AGENT_PROVIDERS=fake node scripts/browser-public-thread-settings-e2e.mjs",
    "test:browser:public-remote-follow": "npm run build && node scripts/browser-public-remote-follow-e2e.mjs",
    "test:browser:public-multi-remote-follow": "npm run build && node scripts/browser-public-multi-remote-follow-e2e.mjs",
    "test:browser:public-core": "node scripts/e2e/run-browser-suite.mjs --suite public-core",
    "test:browser:public-core:fake": "node scripts/e2e/run-browser-suite.mjs --suite public-core --fake",
    "test:browser:public": "node scripts/e2e/run-browser-suite.mjs --suite public-full",
    "test:browser:public:fake": "node scripts/e2e/run-browser-suite.mjs --suite public-full --fake"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@tanstack/query-core": "^5.100.6",
    "@tanstack/virtual-core": "^3.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "vite": "^7.2.1"
  }
}
